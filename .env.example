# Путь до JSON-файла со списком точек. Заполняет менеджер или разработчик.
APP_CONFIG_PATH=config/points.json
# Путь до SQLite-файла внутри контейнера. Доступ не нужен, файл создается автоматически.
APP_DATABASE_PATH=data/review_analysis.sqlite3
# Общий лимит последних отзывов для анализа. Значение определяет бизнес-заказчик.
APP_REVIEW_FETCH_LIMIT=20
# Порядок отзывов перед анализом: newest = от новых к старым, oldest = от старых к новым. Значение определяет бизнес-заказчик.
APP_REVIEW_SORT_ORDER=newest
# Порог звезд для вывода текста нового отзыва в письмо. Значение определяет бизнес-заказчик.
APP_REPORT_STARS_THRESHOLD=4
# Таймаут открытия карточки в секундах. Подбирается разработчиком.
APP_PAGE_TIMEOUT_SECONDS=45
# Дождаться завершения сетевой активности Playwright перед анализом интерфейса. Настраивает разработчик при отладке UI.
APP_PLAYWRIGHT_WAIT_NETWORKIDLE=true
# Дополнительная пауза перед попыткой нажать сортировку в headful-режиме. Используется разработчиком для ручной проверки интерактивности.
APP_PLAYWRIGHT_PAUSE_BEFORE_SORT_SECONDS=0
# Сохранять дополнительные диагностические скриншоты и логи шага сортировки. Включает разработчик при разборе проблем с кликами.
APP_PLAYWRIGHT_SAVE_SORT_DEBUG_STEPS=false
# Пауза между циклами планировщика в секундах. Для weekly-режима можно оставить 60.
APP_SCHEDULER_POLL_SECONDS=60
# Расписание запуска: weekly или daily. Значение определяет бизнес-заказчик.
APP_SCHEDULE_FREQUENCY=weekly
# День недели для weekly-режима: monday, tuesday, wednesday, thursday, friday, saturday, sunday.
APP_SCHEDULE_DAY=monday
# Час запуска по 24-часовому формату. Значение определяет бизнес-заказчик.
APP_SCHEDULE_HOUR=9
# Минута запуска. Значение определяет бизнес-заказчик.
APP_SCHEDULE_MINUTE=0
# Часовой пояс запуска. Берется по часовому поясу сервера или согласуется с заказчиком.
APP_TIMEZONE=Europe/Moscow
# Уровень логирования: DEBUG, INFO, WARNING, ERROR.
APP_LOG_LEVEL=INFO
# ID Google Sheets таблицы. Берется из URL таблицы после /d/.
GOOGLE_SPREADSHEET_ID=
# Путь до JSON-файла сервисного аккаунта Google. Файл нужно получить в Google Cloud и не отправлять в Git.
GOOGLE_SERVICE_ACCOUNT_FILE=secure/google-service-account.json
